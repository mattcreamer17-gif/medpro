<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>404 Page Not Found - MedPro Group</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Font: Nunito Sans (as requested) -->
  <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&display=swap" rel="stylesheet">
  <!-- Empty JSON-LD script (as provided) -->
  <script type="application/ld+json"></script>
</head>

<style>
    :root {
        --f5-404-dark-blue: #003b77;
        --f5-404-mid-blue: #002f6b;
        --f5-404-light-blue: #f4fbfe;
        --f5-404-text: #012f66;
        --f5-404-link: #005a9e;
    }
    
    html, body {
      margin: 0;
      padding: 0;
    }

    @media (min-width: 576px) {
        .f5-404-inner-boundary {
            max-width: 525px;
        }

        .f5-404-content {
            max-width: 525px;
        }
    }
    @media (min-width: 768px) {
        .f5-404-inner-boundary {
            max-width: 705px;
        }

        .f5-404-content {
            max-width: 720px;
        }
    }
    @media (min-width: 992px) {
        .f5-404-inner-boundary {
            max-width: 945px;
        }

        .f5-404-content {
            max-width: 720px;
        }
    }
    @media (min-width: 1200px) {
        .f5-404-inner-boundary {
            max-width: 1125px;
        }

        .f5-404-content {
            max-width: 720px;
        }
    }
    @media (min-width: 1400px) {
        .f5-404-inner-boundary {
            max-width: 1305px;            
        }

        .f5-404-content {
            max-width: 720px;
        }
    }
    
    .f5-404-container {
        margin: 0;
        font-family: "Nunito Sans", Arial, Helvetica, sans-serif;
        background: var(--f5-404-dark-blue);
        color: var(--f5-404-text);
        text-align: center;
        background-color: var(--f5-404-mid-blue);
        overflow-y: scroll;
        height: 100vh; /* Or 100% if html/body are set */
        width: 100vw;
    }

    .f5-404-top-bar {
        background: var(--f5-404-mid-blue);
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-flow: row;
        height: 66px;
    }

    .f5-404-logo {
        display: flex;
        padding-top: 4px;
    }

    .f5-404-logo img {
        min-width: 195px;
        max-width: 100%;
        border: none;
    }

    .f5-404-inner-boundary {
        margin: auto;
        width:100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-flow: row;
        padding-right: 15px;
        padding-left: 15px;
    }

    .f5-404-boundary {
        background-color: white;
    }

    .f5-404-account {
        padding-bottom: 2px;
    }

    .f5-404-account a {
        font-size: 12px;
        font-weight: 600;
        color: white;
        text-decoration: none;
    }

    .f5-404-account a:hover {
        text-decoration: none;
        color: #6d99ba;
    }

    .f5-404-sub-header {
        background: var(--f5-404-light-blue);
        font-size: 13px;
        font-weight: 600;
        color: var(--f5-404-text);
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 50px;
    }

    .f5-404-content {
        padding: 90px 20px;
        margin: auto;
    }

    .f5-404-content h1 {
        font-size: 60px;
        margin-bottom: 20px;
        color: var(--f5-404-text);
        font-weight: 700;
    }

    .f5-404-content p {
        font-size: 18px;
        line-height: 1.45;
        margin-bottom: 30px;
    }

    .f5-404-content div {
        display: inherit;
        margin-top: auto;
        margin-bottom: auto;
    }

    .f5-404-phone {
        color: var(--f5-404-link);
        text-decoration: none;
    }

    .f5-404-phone:hover {
        text-decoration: underline;
    }

    .f5-404-btn {
        display: inline-block;
        padding: 12px 28px;
        font-size: 16px;
        border: 1px solid var(--f5-404-mid-blue);
        border-radius: 6px;
        color: var(--f5-404-mid-blue);
        background: white;
        cursor: pointer;
        text-decoration: none;
    }

    .f5-404-btn:hover {
        background: var(--f5-404-mid-blue);
        color: #ffffff;
        text-decoration: none;
    }

    .f5-404-company-name {
        padding-top: 1px;
    }

</style>
</head>

<body>
  <div class="f5-404-container">
    <div class="f5-404-top-bar">
      <div class="f5-404-inner-boundary">
        <div class="f5-404-logo">
            <a href="https://www.medpro.com">
                <img src="F5ErrorPage/mpglogowhite.svg" alt="MedPro Group Logo">
            </a>
        </div>
        <div class="f5-404-account">
            <a href="https://www.medpro.com/my-account">My account</a>
        </div>
      </div>
    </div>

    <div class="f5-404-sub-header">
      <div class="f5-404-inner-boundary f5-404-company-name">
        a Berkshire Hathaway company
      </div>
    </div>

    <div class="f5-404-boundary">
      <div class="f5-404-content">
          <h1>Page not found</h1>
          <p>
              We’re sorry, the page you’re trying to view may be an old link or might have moved.
              If you have questions or continue to receive this message, please call us at
              <a href="tel:8004633776" class="f5-404-phone">(800) 463‑3776</a> for help.
          </p>
          <a href="https://www.medpro.com" class="f5-404-btn">Go to home page</a>
      </div>
    </div>
  </div>
</body>
</html>
